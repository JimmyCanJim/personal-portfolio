      "text": "my-portfolio-website/\n├── index.html\n├── css/\n│   ├── style.css\n│   ├── components/\n│   │   ├── header.css\n│   │   ├── about.css\n│   │   ├── portfolio.css\n│   │   ├── contact.css\n│   │   └── blog.css\n│   └── utilities/\n│       ├── reset.css\n│       └── variables.css\n├── js/\n│   ├── main.js\n│   ├── modules/\n│   │   ├── scroll-effects.js\n│   │   ├── contact-modal.js\n│   │   ├── portfolio-filter.js\n│   │   └── blog-loader.js\n│   └── utils/\n│       ├── helpers.js\n│       └── animations.js\n├── images/\n│   ├── logos/\n│   │   ├── html5-logo.png\n│   │   ├── css3-logo.png\n│   │   ├── javascript-logo.png\n│   │   └── [other tool logos]\n│   ├── profile-pic.jpg\n│   └── projects/\n│       ├── project1-screenshot.png\n│       └── project2-screenshot.png\n├── blog/\n│   ├── index.html\n│   ├── css/\n│   │   └── blog.css\n│   └── posts/\n│       ├── ut-design-website.html\n│       ├── ut-design-app.html\n│       └── back-ped.html\n└── assets/\n    ├── fonts/\n    └── icons/",
